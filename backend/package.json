{
  "name": "@aisoftco/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "mcp": "tsx watch src/mcp/index.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/",
