{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm --prefix .. install",
  "buildCommand": "npm --prefix .. run build --workspace=shared",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
