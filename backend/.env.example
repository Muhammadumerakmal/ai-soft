# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ai_soft_comp

# Auth
JWT_SECRET=your-secret-key-at-least-32-characters-long

# CORS
CORS_ORIGIN=http://localhost:3000

# OpenRouter (recommended)
OPENROUTER_API_KEY=sk-or-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o

# OpenAI (fallback if OpenRouter not set)
OPENAI_API_KEY=sk-your-openai-api-key

# MCP Servers (set MCP_ENABLED=true to activate)
MCP_ENABLED=false
GITHUB_TOKEN=ghp_your-github-token
MCP_ALLOWED_DIRS=./frontend,./backend,./docs

# Context7 API for documentation lookup
CONTEXT7_API_KEY=ctx7sk-your-context7-key

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
